# CF-Connecting-IP contains the real client IP set by Cloudflare (Render uses CF as CDN).
# $binary_remote_addr is always 127.0.0.1 on Render (internal loopback routing),
# which would make all users share one bucket — using CF header fixes per-user limiting.
map $http_cf_connecting_ip $rate_limit_key {
    default $http_cf_connecting_ip;
    ""      $binary_remote_addr;     # fallback para Docker local (sem Cloudflare)
}
limit_req_zone $rate_limit_key zone=agent_limit:10m rate=60r/m;

# Defer upstream DNS resolution to request time so nginx starts even if
# downstream services are still booting (common on Render free tier).
# Local Docker Compose: NGINX_RESOLVER=127.0.0.11 (Docker embedded DNS)
# Render free tier:     NGINX_RESOLVER=1.1.1.1 8.8.8.8 (public DNS for public URLs)
resolver ${NGINX_RESOLVER} valid=30s ipv6=off;

# Required for HTTPS upstreams (Render public URLs use SNI-based SSL).
proxy_ssl_server_name on;

server {
    listen 8080;
    server_name _;

    # Configurações globais de proxy (SSE/streaming)
    proxy_http_version        1.1;
    proxy_set_header          Host $host;
    proxy_set_header          X-Real-IP $remote_addr;
    proxy_set_header          X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_read_timeout        300s;
    chunked_transfer_encoding on;

    # ── Health check sem auth (usado pelo Render) ────────────────────────────
    location = /health {
        return 200 'ok';
        add_header Content-Type text/plain;
    }

    # ── LangGraph Server (agent) — paths conhecidos do SDK ───────────────────
    # Autenticação + rate limit ficam SOMENTE aqui (UI/assets não precisam de token).
    # Falha fechado: se LANGGRAPH_AUTH_TOKEN não estiver definido, retorna 500.
    location ~ ^/(threads|runs|assistants|store|info|ok|version|metrics)(/|$) {
        set $expected_token "${LANGGRAPH_AUTH_TOKEN}";
        if ($expected_token = "") {
            return 500 '{"error":"LANGGRAPH_AUTH_TOKEN not configured"}';
        }
        if ($http_x_api_key = "") {
            return 401 '{"error":"Unauthorized"}';
        }
        if ($http_x_api_key != $expected_token) {
            return 401 '{"error":"Unauthorized"}';
        }

        # Rate limiting: 20 req/min, burst de 10 sem delay
        limit_req        zone=agent_limit burst=30 nodelay;
        limit_req_status 429;

        # SSE: desabilita buffering para streaming token-a-token
        proxy_buffering           off;
        proxy_cache               off;
        proxy_set_header          Connection "";
        chunked_transfer_encoding off;
        gzip                      off;
        proxy_max_temp_file_size  0;

        # LANGGRAPH_UPSTREAM must be a variable for resolver-based deferred lookup.
        # Full URL including scheme: http://... (local) or https://... (Render).
        set $langgraph_upstream "${LANGGRAPH_UPSTREAM}";
        proxy_pass $langgraph_upstream;
    }

    # ── Chat UI (Next.js) — everything else ──────────────────────────────────
    location / {
        # WebSocket upgrade para HMR em dev (ignorado em prod)
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_buffering off;
        # Full URL including scheme: http://... (local) or https://... (Render).
        set $ui_upstream "${UI_UPSTREAM}";
        proxy_pass $ui_upstream;

        # Se a UI retornar 429 (Render free tier hibernando), exibe página de espera
        # em vez de repassar o 429 ao browser.
        proxy_intercept_errors on;
        error_page 429 503 502 /warming.html;
    }

    location = /warming.html {
        root /usr/share/nginx/html;
        internal;
    }
}
