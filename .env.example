# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LangSmith ────────────────────────────────────────────────────────────────
# Uma única chave serve para licença do langgraph-server E tracing.
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=AgendAI
# Descomente se estiver no servidor EU:
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# ── Postgres (API) ────────────────────────────────────────────────────────────
# Dev local (docker compose): valor abaixo funciona sem alterar.
# Produção (Neon): postgres://user:pass@ep-xxx.neon.tech/agendai_app?sslmode=require
DATABASE_URL=postgres://agendai:agendai@postgres:5432/agendai

# ── Postgres (LangGraph Server — checkpoints/threads) ─────────────────────────
# Dev local: valor abaixo funciona sem alterar.
# Produção (Neon): postgres://user:pass@ep-xxx.neon.tech/agendai_lg?sslmode=require
DATABASE_URI=postgres://agendai:agendai@postgres:5432/agendai_lg

# ── Redis (SSE streaming do langgraph-server) ─────────────────────────────────
# Dev local: valor abaixo funciona sem alterar.
# Produção (Upstash): rediss://default:xxx@xxx.upstash.io:6379
REDIS_URI=redis://redis:6379

# ── Nginx / gateway ──────────────────────────────────────────────────────────
# Token compartilhado: nginx (x-api-key) ↔ UI (NEXT_PUBLIC_LANGGRAPH_API_KEY)
# Gere com: openssl rand -hex 32
LANGGRAPH_AUTH_TOKEN=seu-token-secreto-aqui

# ── API Express ───────────────────────────────────────────────────────────────
PORT=3000
API_BASE_URL=http://api:3000

# ── E-mail via Resend (opcional) ─────────────────────────────────────────────
# Resend HTTP API — 3.000 e-mails/mês grátis. https://resend.com
# Sem RESEND_API_KEY o sistema funciona normalmente (confirmação exibida só no chat).
RESEND_API_KEY=re_...
EMAIL_FROM=AgendAI <onboarding@resend.dev>
