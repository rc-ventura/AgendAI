# OpenAI API Key — usado pelo agente LangGraph para LLM (GPT-4o-mini), Whisper (STT) e TTS
OPENAI_API_KEY=sk-...

# Porta da API Express
PORT=3000

# Caminho do banco SQLite DENTRO do container Docker
# O volume ./data:/app/data mapeia a pasta local data/ para /app/data no container
DB_PATH=/app/data/clinica.db

# test /
NODE_ENV=test

# ── LangGraph Agent ──────────────────────────────────────────────────────────

# LangSmith observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=AgendAI

# Gmail SMTP (use App Password — not your regular password)
# How to generate: myaccount.google.com → Security → App passwords
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Internal API URL (used inside Docker Compose network)
API_BASE_URL=http://api:3000

# ── Nginx Proxy ───────────────────────────────────────────────────────────────
# Token para autenticar chamadas ao LangGraph server (porta 8080).
# O nginx valida o header `x-api-key` contra este valor; a porta interna 8123
# não é exposta ao host. Se a variável estiver vazia, o nginx falha fechado
# (responde 500). Gere com: openssl rand -hex 32
# O agent-ui (via @langchain/langgraph-sdk) envia automaticamente o header
# `x-api-key: <token>` quando NEXT_PUBLIC_LANGGRAPH_API_KEY estiver setada.
LANGGRAPH_AUTH_TOKEN=seu-token-secreto-aqui