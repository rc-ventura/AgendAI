# ── OpenAI ───────────────────────────────────────────────────────────────────
# Obrigatório para GPT-4o-mini (LLM), Whisper (STT) e TTS
OPENAI_API_KEY=sk-...

# ── API Express ───────────────────────────────────────────────────────────────
PORT=3000

# ── Banco de dados (Postgres) ─────────────────────────────────────────────────
# Produção / dev remoto: Neon Postgres (database: agendai_app)
#   postgres://user:pass@ep-xxx.neon.tech/agendai_app?sslmode=require
# Dev local (docker compose): postgres://agendai:agendai@postgres:5432/agendai
DATABASE_URL=postgres://agendai:agendai@postgres:5432/agendai

# ── LangGraph Server ──────────────────────────────────────────────────────────
# Neon Postgres separado para estado do agente (database: agendai_lg)
#   postgres://user:pass@ep-xxx.neon.tech/agendai_lg?sslmode=require
# Dev local (docker compose): postgres://agendai:agendai@postgres:5432/agendai_lg
DATABASE_URI=postgres://agendai:agendai@postgres:5432/agendai_lg

# Upstash Redis — obrigatório para SSE streaming do langgraph-server
#   Produção: rediss://default:xxx@xxx.upstash.io:6379
#   Dev local (docker compose): redis://redis:6379
REDIS_URI=redis://redis:6379

# LangSmith Developer plan — OBRIGATÓRIO para o langgraph-server (license key)
LANGSMITH_API_KEY=lsv2_sk_...

# ── LangSmith observabilidade / tracing ───────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=AgendAI

# ── Gmail SMTP (opcional) ─────────────────────────────────────────────────────
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Rede interna Docker Compose ───────────────────────────────────────────────
# URL da API usada pelo agente dentro da rede Docker
API_BASE_URL=http://api:3000

# ── Nginx (gateway) ───────────────────────────────────────────────────────────
# Token compartilhado: nginx valida x-api-key; UI envia como NEXT_PUBLIC_LANGGRAPH_API_KEY
LANGGRAPH_AUTH_TOKEN=seu-token-secreto-aqui
