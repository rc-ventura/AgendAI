# ── OpenAI ───────────────────────────────────────────────────────────────────
# Obrigatório: LLM (GPT-4o-mini), Whisper (STT), TTS
OPENAI_API_KEY=sk-...

# ── LangSmith ────────────────────────────────────────────────────────────────
# Uma única chave LangSmith (lsv2_pt_...) serve para dois papéis:
#   LANGSMITH_API_KEY  — license key exigida pelo langgraph-server para subir
#   LANGCHAIN_API_KEY  — tracing key usada pelo SDK para enviar traces
# São a MESMA chave; copie o valor nos dois campos.
LANGSMITH_API_KEY=lsv2_pt_...
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=AgendAI

# ── Postgres (API) ────────────────────────────────────────────────────────────
# Dev local (docker compose): padrão abaixo funciona sem alterar
# Produção (Neon, database: agendai_app): postgres://user:pass@ep-xxx.neon.tech/agendai_app?sslmode=require
DATABASE_URL=postgres://agendai:agendai@postgres:5432/agendai

# ── Postgres (LangGraph Server) ───────────────────────────────────────────────
# Banco separado para checkpoints/threads do agente (não misturar com API)
# Dev local: padrão abaixo funciona sem alterar
# Produção (Neon, database: agendai_lg): postgres://user:pass@ep-xxx.neon.tech/agendai_lg?sslmode=require
DATABASE_URI=postgres://agendai:agendai@postgres:5432/agendai_lg

# ── Redis (LangGraph Server — SSE streaming) ──────────────────────────────────
# Dev local: padrão abaixo funciona sem alterar
# Produção (Upstash): rediss://default:xxx@xxx.upstash.io:6379
REDIS_URI=redis://redis:6379

# ── Nginx / gateway ──────────────────────────────────────────────────────────
# Token compartilhado entre nginx (x-api-key) e UI (NEXT_PUBLIC_LANGGRAPH_API_KEY)
# Gere com: openssl rand -hex 32
LANGGRAPH_AUTH_TOKEN=seu-token-secreto-aqui

# ── API Express ───────────────────────────────────────────────────────────────
PORT=3000

# ── URL interna (agent → api dentro do Docker) ───────────────────────────────
API_BASE_URL=http://api:3000

# ── Gmail SMTP (opcional — confirmação de agendamento por e-mail) ─────────────
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
